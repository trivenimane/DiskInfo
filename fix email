// ---------- BUILD CSV REPORT ----------
var lines = [];

// Header
lines.push("VM_Name,VM_ID,Status,Category,Tag,Error");

// Success entries
for (var i = 0; i < successList.length; i++) {
    lines.push(successList[i] + ",SUCCESS");
}

// Failure entries
for (var i = 0; i < failureList.length; i++) {
    lines.push(failureList[i] + ",FAILED");
}

var csvContentFinal = lines.join("\n");

------
var dateInfo = new Date().getTime();

var filePath = "SBI Meghdoot/Reports/TaggingReport/TaggingReport-" + dateInfo + ".csv";

var reportRE = new ResourceElementAccessor_1._.ResourceElementAccessor(filePath, false);
reportRE.setContent(csvContentFinal);

System.log("Tagging report saved on: " + filePath);
-----
var listOfAttachments = [];

var baseBuilder = new BaseBuilder_1._.BaseBuilder();

var fileName = filePath.split("/").pop();
var fileContent = reportRE.getContent();

var csvAttachment = baseBuilder.createAttachment(fileName, fileContent);
listOfAttachments.push(csvAttachment);
---------
var requestorName = System.getContext().getParameter("__metadata_userName");

var requestorEmail = new UserService_1._.UserService().getEmailAddress(requestorName);

System.log("Requestor: " + requestorName);
System.log("Email: " + requestorEmail);
----------

var emailService = new EmailService_1._.EmailService();

emailService.diskInfoNotification(
    requestorEmail,
    requestorName,
    listOfAttachments
);

System.log("Email sent to " + requestorEmail);
